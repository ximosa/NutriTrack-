# Public key used by the browser (optional, fallback DEMO_KEY)
VITE_USDA_API_KEY="YOUR_USDA_API_KEY"

# Optional. If empty, frontend uses same-origin endpoint: /api/weekly-plan
VITE_AI_PROXY_URL=""

# Server-side secret used by Vercel Function api/weekly-plan.ts
# Never expose this in frontend code.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
